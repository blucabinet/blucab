DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost

# Superuser initialization.
# You should delete those entries after the first docker container run!
# Select your own unique password!
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=**********
DJANGO_SUPERUSER_EMAIL=example@example.com

# Django EMAIL
DJANGO_EMAIL_ENABLE=False
DJANGO_EMAIL_HOST=smtp.localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_HOST_USER=example@localhost
DJANGO_EMAIL_HOST_PASSWORD="**********"
DJANGO_EMAIL_SUBJECT_PREFIX="[blucab] "
DJANGO_EMAIL_USE_LOCALTIME=True
DJANGO_EMAIL_ENABLE_WHILE_DEBUG=False
DJANGO_EMAIL_FROM_NOREPLY=no-reply@localhost
DJANGO_EMAIL_ADMIN=admin@localhost

#Django database
DJANGO_DB_ENGINE=mysql
DJANGO_DB_NAME=blucab
DJANGO_DB_USER=blucab
DJANGO_DB_PASSWORD=blucab
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# Celery settings
DJANGO_CELERY_BROKER_URL="redis://blucab-redis:6379/0"

# Blucab settings
BLUCAB_ALLOW_REGISTER=False
BLUCAB_ALLOW_API=False
BLUCAB_ALLOW_CSV_MOVIE_IMPORT=True
BLUCAB_DEFAULT_LANGUAGE=en
BLUCAB_ALLOW_MOVIE_ERROR_REPORT=True
